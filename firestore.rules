rules_version = '2';

// ============================================================
// ERP Nexus — Firestore security rules
// ============================================================
// Auth model: Firebase Authentication (email/password).
//
// Key design decisions:
//  • isAdmin() reads the caller's nexus_users profile on the server —
//    setting isAdmin:true in localStorage cannot bypass this.
//  • nexus_users allows anonymous reads (needed for the one-time
//    legacy migration login that queries by username).
//  • nexus_meta/bootstrap_status is publicly readable so the login
//    page can detect a fresh install without any auth.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers --------------------------------------------------------

    function isPasswordAuth() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == "password";
    }

    function callerProfile() {
      return get(/databases/$(database)/documents/nexus_users/$(request.auth.uid)).data;
    }

    // Server-side admin check — cannot be faked via localStorage.
    function isAdmin() {
      return isPasswordAuth() && callerProfile().isAdmin == true;
    }

    function inSite(siteId) {
      return isAdmin() || siteId in callerProfile().sites;
    }

    // ---- nexus_users ----------------------------------------------------
    // READ  : any authenticated session (anonymous OK — needed for legacy
    //         migration query and bootstrap check).
    // CREATE: user creates own profile (bootstrap + migration) OR admin
    //         creates another user's profile.
    // UPDATE: user updates own profile OR admin updates any.
    // DELETE: blocked via client API.
    match /nexus_users/{userId} {
      allow read   : if request.auth != null;
      allow create : if request.auth.uid == userId || isAdmin();
      allow update : if request.auth.uid == userId || isAdmin();
      allow delete : if false;
    }

    // ---- bootstrap status (publicly readable, written once) -------------
    // The login page reads this to decide whether to show the login form
    // or the first-admin setup form — no auth required.
    match /nexus_meta/bootstrap_status {
      allow read  : if true;
      allow create: if !exists(/databases/$(database)/documents/nexus_meta/bootstrap_status);
      allow update, delete: if isAdmin();
    }

    // ---- public offer submission (offer-submit.html) --------------------
    match /nexus_offers/{offerId} {
      allow read         : if isPasswordAuth() && inSite(resource.data.siteId);
      allow update, delete: if isPasswordAuth() && inSite(resource.data.siteId);
      allow create       : if request.auth != null
                           && request.resource.data.keys().hasOnly([
                                'siteId','supplierId','supplierName','items','price',
                                'validity','contact','note','status','source',
                                'token','createdAt','createdBy'
                              ])
                           && request.resource.data.items is string
                           && request.resource.data.price is number
                           && request.resource.data.price >= 0;
    }

    // ---- contract signing (contract-sign.html) --------------------------
    match /nexus_contracts/{doc} {
      allow read          : if isPasswordAuth();
      allow create, delete: if isPasswordAuth();
      allow update        : if request.auth != null
                            && request.resource.data.diff(resource.data).affectedKeys()
                                 .hasOnly(['status','signature','signedAt','signerName']);
    }

    // ---- scoped collections ---------------------------------------------
    match /nexus_suppliers/{doc} {
      allow read : if isPasswordAuth() && inSite(resource.data.siteId);
      allow write: if isPasswordAuth() && inSite(request.resource.data.siteId)
                   && request.resource.data.siteId is string
                   && request.resource.data.siteId.size() > 0;
    }
    match /nexus_materials/{doc} {
      allow read : if isPasswordAuth() && inSite(resource.data.siteId);
      allow write: if isPasswordAuth() && inSite(request.resource.data.siteId)
                   && request.resource.data.siteId is string
                   && request.resource.data.siteId.size() > 0;
    }
    match /nexus_prs/{doc} {
      allow read : if isPasswordAuth() && inSite(resource.data.siteId);
      allow write: if isPasswordAuth() && inSite(request.resource.data.siteId)
                   && request.resource.data.siteId is string
                   && request.resource.data.siteId.size() > 0;
    }

    // ---- other app collections ------------------------------------------
    match /nexus_psi/{doc}              { allow read, write: if isPasswordAuth(); }
    match /nexus_attendance/{doc}       { allow read, write: if isPasswordAuth(); }
    match /nexus_sites/{doc}            { allow read, write: if isPasswordAuth(); }
    match /nexus_notifications/{doc}    { allow read, write: if isPasswordAuth(); }
    match /nexus_activity/{doc}         { allow read, write: if isPasswordAuth(); }
    match /nexus_settings/{doc}         { allow read, write: if isPasswordAuth(); }
    match /nexus_quotes/{doc}           { allow read, write: if isPasswordAuth(); }
    match /nexus_negotiations/{doc}     { allow read, write: if isPasswordAuth(); }
    match /nexus_schedules/{doc}        { allow read, write: if isPasswordAuth(); }
    match /nexus_whatsapp_tokens/{doc}  { allow read, write: if isPasswordAuth(); }
    match /nexus_meta/{doc}             { allow read, write: if isPasswordAuth(); }

    match /{document=**} { allow read, write: if false; }
  }
}
