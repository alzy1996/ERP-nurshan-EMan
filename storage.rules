rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // App uploads: only a real (password) signed-in user, writing into THEIR
    // OWN folder. Blocks anonymous uploads and cross-folder writes.
    match /{folder}/{uid}/{file} {
      allow read: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
      allow write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password'
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/jpeg|image/png|application/pdf|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    // Public contract-signing signatures — the signer may be anonymous, so this
    // stays open to any authenticated session but is strictly size/type limited.
    match /signatures/{uid}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/png');
    }

    // Deny everything else.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
